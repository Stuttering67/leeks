<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="leeks.SettingsWindow">
  <grid id="27dc6" binding="panel1" default-binding="true" layout-manager="FormLayout">
    <rowspec value="center:max(d;4px):noGrow"/>
    <rowspec value="top:4dlu:noGrow"/>
    <rowspec value="center:max(d;4px):noGrow"/>
    <rowspec value="top:4dlu:noGrow"/>
    <rowspec value="center:max(d;4px):noGrow"/>
    <colspec value="left:119px:noGrow"/>
    <colspec value="left:13dlu:noGrow"/>
    <colspec value="left:d:grow"/>
    <colspec value="left:30dlu:noGrow"/>
    <colspec value="fill:d:grow"/>
    <constraints>
      <xy x="20" y="20" width="1004" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <tabbedpane id="e57b" binding="tabbedPane1" default-binding="true">
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="5" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false">
            <preferred-size width="200" height="200"/>
          </grid>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <grid id="522ba" layout-manager="FormLayout">
            <rowspec value="center:max(d;4px):noGrow"/>
            <rowspec value="top:4dlu:noGrow"/>
            <rowspec value="center:d:grow"/>
            <colspec value="left:0px:grow"/>
            <colspec value="left:4dlu:noGrow"/>
            <colspec value="fill:d:grow"/>
            <colspec value="left:4dlu:noGrow"/>
            <colspec value="fill:d:grow"/>
            <constraints>
              <tabbedpane title="基金"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children>
              <component id="bf47d" class="javax.swing.JLabel">
                <constraints>
                  <grid row="0" column="0" row-span="1" col-span="5" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <text value="基金编码，英文分号分隔（持仓成本价和持仓份额跟在基金编码后，用英文逗号分隔）："/>
                </properties>
              </component>
              <scrollpane id="f10a8">
                <constraints>
                  <grid row="2" column="0" row-span="1" col-span="5" vsize-policy="7" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children>
                  <component id="732f5" class="javax.swing.JTextArea" binding="textAreaFund">
                    <constraints/>
                    <properties>
                      <lineWrap value="true"/>
                      <rows value="10"/>
                      <toolTipText value="基金编码，英文分号分隔，例如:【001632,3.2050,951.64;002340,4.2820,467.07】"/>
                    </properties>
                  </component>
                </children>
              </scrollpane>
            </children>
          </grid>
          <grid id="c8ca2" layout-manager="FormLayout">
            <rowspec value="center:max(d;4px):noGrow"/>
            <rowspec value="top:4dlu:noGrow"/>
            <rowspec value="center:d:grow"/>
            <colspec value="left:0px:grow"/>
            <colspec value="left:4dlu:noGrow"/>
            <colspec value="fill:d:grow"/>
            <colspec value="left:4dlu:noGrow"/>
            <colspec value="fill:d:grow"/>
            <constraints>
              <tabbedpane title="股票"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children>
              <component id="f57a1" class="javax.swing.JLabel">
                <constraints>
                  <grid row="0" column="0" row-span="1" col-span="5" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <text value="股票编码，英文分号分隔（成本价和持仓接在编码后用逗号分隔）："/>
                </properties>
              </component>
              <scrollpane id="e0430">
                <constraints>
                  <grid row="2" column="0" row-span="1" col-span="5" vsize-policy="7" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children>
                  <component id="1567c" class="javax.swing.JTextArea" binding="textAreaStock">
                    <constraints/>
                    <properties>
                      <lineWrap value="true"/>
                      <rows value="10"/>
                      <toolTipText value="股票编码，例如：【sh000001,12.451,1200;hk00700,13.412,2000】"/>
                    </properties>
                  </component>
                </children>
              </scrollpane>
            </children>
          </grid>
          <grid id="b3ed2" layout-manager="FormLayout">
            <rowspec value="center:max(d;4px):noGrow"/>
            <rowspec value="top:4dlu:noGrow"/>
            <rowspec value="center:d:grow"/>
            <colspec value="left:0px:grow"/>
            <colspec value="left:4dlu:noGrow"/>
            <colspec value="fill:d:grow"/>
            <colspec value="left:4dlu:noGrow"/>
            <colspec value="fill:d:grow"/>
            <constraints>
              <tabbedpane title="加密货币"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children>
              <component id="9bf70" class="javax.swing.JLabel">
                <constraints>
                  <grid row="0" column="0" row-span="1" col-span="5" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <text value="虚拟币编码，英文逗号分隔：(虚拟币行情必须使用代理才能查看)"/>
                </properties>
              </component>
              <scrollpane id="63733">
                <constraints>
                  <grid row="2" column="0" row-span="1" col-span="5" vsize-policy="7" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children>
                  <component id="149ff" class="javax.swing.JTextArea" binding="textAreaCoin">
                    <constraints/>
                    <properties>
                      <lineWrap value="true"/>
                      <rows value="10"/>
                      <toolTipText value="英文逗号分隔，例如：【BTC-USD,DOGE-USD】注意编码大写，一般格式为[币编码-USD]"/>
                    </properties>
                  </component>
                </children>
              </scrollpane>
            </children>
          </grid>
        </children>
      </tabbedpane>
    </children>
  </grid>
</form>
